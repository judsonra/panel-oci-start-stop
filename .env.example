POSTGRES_DB=oci_automation
POSTGRES_USER=oci_user
POSTGRES_PASSWORD=oci_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://oci_user:oci_password@postgres:5432/oci_automation
OCI_CLI_PATH=oci
OCI_CLI_PROFILE=DEFAULT
OCI_CONFIG_DIR=/home/appuser/.oci
AUTH_ENABLED=false
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URL=
ALLOWED_GROUPS=
APP_TIMEZONE=UTC
SCHEDULER_POLL_SECONDS=30
SCHEDULER_ENABLED=true
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
API_BASE_URL=http://localhost:8000/api
